{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "norii",
  "version": "0.1.0",
  "identifier": "com.norii.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "norii",
        "width": 1024,
        "height": 768
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: asset:; connect-src 'self'"
    }
  },
  "bundle": {
    "active": false
  }
}
